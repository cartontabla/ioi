[
  {
    "id": "1",
    "type": "tab",
    "label": "SmartCam - example",
    "disabled": false,
    "info": "Flujo simple: captura trigger -> MQTT event -> fetch image -> save file"
  },
  {
    "id": "mqtt-in-1",
    "type": "mqtt in",
    "z": "1",
    "name": "camera events",
    "topic": "camera/event",
    "qos": "0",
    "broker": "mqtt-broker",
    "x": 140,
    "y": 80,
    "wires": [["json-1"]]
  },
  {
    "id": "json-1",
    "type": "json",
    "z": "1",
    "name": "parse JSON",
    "property": "payload",
    "action": "obj",
    "pretty": false,
    "x": 320,
    "y": 80,
    "wires": [["debug-1","http-request-2"]]
  },
  {
    "id": "debug-1",
    "type": "debug",
    "z": "1",
    "name": "events",
    "active": true,
    "tosidebar": true,
    "console": false,
    "x": 500,
    "y": 80,
    "wires": []
  },
  {
    "id": "http-request-2",
    "type": "http request",
    "z": "1",
    "name": "fetch image",
    "method": "GET",
    "ret": "bin",
    "url": "http://<RPI_IP>:5000{{payload.path}}",
    "tls": "",
    "x": 520,
    "y": 140,
    "wires": [["file-1"]]
  },
  {
    "id": "inject-1",
    "type": "inject",
    "z": "1",
    "name": "Trigger capture",
    "props": [{"p":"payload"}],
    "repeat": "",
    "crontab": "",
    "once": false,
    "onceDelay": 0.1,
    "topic": "",
    "payload": "",
    "payloadType": "str",
    "x": 140,
    "y": 180,
    "wires": [["http-request-1"]]
  },
  {
    "id": "http-request-1",
    "type": "http request",
    "z": "1",
    "name": "capture",
    "method": "POST",
    "ret": "obj",
    "url": "http://<RPI_IP>:5000/api/capture",
    "tls": "",
    "x": 330,
    "y": 180,
    "wires": [["debug-2"]]
  },
  {
    "id": "file-1",
    "type": "file",
    "z": "1",
    "name": "save.jpg",
    "filename": "/tmp/capture.jpg",
    "appendNewline": false,
    "createDir": false,
    "overwriteFile": true,
    "encoding": "none",
    "x": 560,
    "y": 180,
    "wires": []
  },
  {
    "id": "debug-2",
    "type": "debug",
    "z": "1",
    "name": "capture result",
    "active": true,
    "tosidebar": true,
    "console": false,
    "x": 560,
    "y": 240,
    "wires": []
  },
  {
    "id": "mqtt-broker",
    "type": "mqtt-broker",
    "z": "1",
    "name": "local",
    "broker": "localhost",
    "port": "1883",
    "clientid": "",
    "usetls": false,
    "compatmode": true,
    "keepalive": "60",
    "cleansession": true,
    "birthTopic": "",
    "birthQos": "0",
    "birthPayload": "",
    "closeTopic": "",
    "closePayload": "",
    "willTopic": "",
    "willQos": "0",
    "willPayload": ""
  }
]
